HTTP_ADDR=:8080
NSQD_ADDRESS=127.0.0.1:4150
NSQD_HTTP_ADDRESS=127.0.0.1:4151
NSQ_MAX_IN_FLIGHT=200
NSQ_EVENT_CONCURRENCY=1
NSQ_LOG_CONCURRENCY=1
POSTGRES_URL=postgres://logtap:logtap@127.0.0.1:5432/logtap?sslmode=disable
#
# When true, startup migration fails fast unless TimescaleDB extension is available
# and hypertables can be created (recommended for production/cloud).
DB_REQUIRE_TIMESCALE=false
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=1
DB_LOG_BATCH_SIZE=200
DB_LOG_FLUSH_INTERVAL=50ms
DB_EVENT_BATCH_SIZE=200
DB_EVENT_FLUSH_INTERVAL=50ms
CLEANUP_INTERVAL=10m
CLEANUP_POLICY_LIMIT=50
CLEANUP_DELETE_BATCH_SIZE=5000
CLEANUP_MAX_BATCHES=50
CLEANUP_BATCH_SLEEP=0s
RUN_CONSUMERS=true
#
# Alerting worker (outbox delivery).
# - If false, alerts can be enqueued but won't be delivered unless you run the standalone `alert-worker` binary.
RUN_ALERT_WORKER=false
# Optional: cleanup alert tables (set > 0 to enable).
ALERT_CLEANUP_INTERVAL=1h
ALERT_DELIVERIES_RETENTION_DAYS=0
ALERT_STATES_RETENTION_DAYS=0
#
# Webhook SSRF protection (defaults deny).
# - For local dev / tests you may allow loopback.
WEBHOOK_ALLOW_LOOPBACK=false
WEBHOOK_ALLOW_PRIVATE_IPS=false
# Optional: allow specific internal networks (CIDR list, comma/space separated)
WEBHOOK_ALLOWLIST_CIDRS=
#
# SMTP / Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_USERNAME=
SMTP_PASSWORD=
#
# SMS (optional)
# SMS_PROVIDER=aliyun|tencent
SMS_PROVIDER=
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_REGION=cn-hangzhou
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_REGION=ap-guangzhou
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
ENABLE_METRICS=true
METRICS_DAY_TTL=4320h
METRICS_DIST_TTL=2160h
METRICS_MONTH_TTL=13392h
GEOIP_CITY_MMDB=
GEOIP_ASN_MMDB=
MAXMIND_LICENSE_KEY=
AUTH_SECRET=
AUTH_SECRET_FILE=
AUTH_TOKEN_TTL=168h
MAINTENANCE_MODE=false
ENABLE_DEBUG_ENDPOINTS=false
#
# Optional: trusted upstream protection for logtap-cloud.
# When set, /api/:projectId/* requires header X-Logtap-Proxy-Secret.
LOGTAP_PROXY_SECRET=
