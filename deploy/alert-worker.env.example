# Required
POSTGRES_URL=postgres://logtap:logtap@127.0.0.1:5432/logtap?sslmode=disable

# Optional: webhook SSRF policy
WEBHOOK_ALLOW_LOOPBACK=false
WEBHOOK_ALLOW_PRIVATE_IPS=false
WEBHOOK_ALLOWLIST_CIDRS=

# Optional: cleanup
ALERT_CLEANUP_INTERVAL=1h
ALERT_DELIVERIES_RETENTION_DAYS=0
ALERT_STATES_RETENTION_DAYS=0

# Optional: email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_USERNAME=
SMTP_PASSWORD=

# Optional: SMS
# SMS_PROVIDER=aliyun|tencent
SMS_PROVIDER=
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_REGION=cn-hangzhou
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_REGION=ap-guangzhou
